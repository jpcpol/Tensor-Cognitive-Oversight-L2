# Copy to .env and fill in real values — never commit .env to git

# ── API Keys ──────────────────────────────────────────────────────────────────
# Option A: Anthropic direct
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenRouter (acceso a todos los modelos Anthropic + otros)
# Documentación: https://openrouter.ai/docs
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelo activo (usado por qa_agent, pipeline, tco_engine)
# Anthropic vía OpenRouter: anthropic/claude-sonnet-4-6
# Anthropic vía OpenRouter: anthropic/claude-opus-4-7
# Anthropic directo:        claude-sonnet-4-6
LLM_PROVIDER=openrouter          # openrouter | anthropic
LLM_MODEL=anthropic/claude-sonnet-4-6

# Database
POSTGRES_DB=tco_experiment
POSTGRES_USER=tco
POSTGRES_PASSWORD=tco
DATABASE_URL=postgresql://tco:tco@localhost:5432/tco_experiment

# Redis
REDIS_URL=redis://localhost:6379/0

# Services
TCO_ENGINE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Experiment
EXPERIMENT_MODE=development   # development | pilot | full
TENSOR_CACHE_TTL=30           # seconds
POLICY_WINDOW_CYCLES=3        # Δ_post measurement window (H5)
